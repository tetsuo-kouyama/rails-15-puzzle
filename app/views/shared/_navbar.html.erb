<nav class="minimal-nav">
  <div class="nav-container">
    <div class="nav-left">
      <% unless current_page?(root_path) %>
        <% destination = controller_name == 'puzzles' && action_name == 'show' ? (request.referer || root_path) : root_path %>
        <%= link_to t('navbar.return'), destination, class: "nav-link" %>
      <% end %>
    </div>

    <div class="nav-right">
      <% if logged_in? %>
        <span class="user-name"><%= current_user.name.presence || t('navbar.guest_user') %></span>
        <%= link_to t('navbar.logout'), logout_path, data: { turbo_method: :delete }, class: 'nav-link' %>
      <% else %>
        <%= link_to t('navbar.login'), login_path, class: "nav-link" %>
        <%= link_to t('navbar.new_registration'), new_user_path, class: "nav-link" %>
      <% end %>
    </div>
  </div>
</nav>
