<div>
  <h1>ログイン</h1>

  <% if flash[:alert] %>
    <div style="color: red;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: login_path, scope: :session do |f| %>
    <div>
      <%= f.label :name, "ユーザー名" %>
      <%= f.text_field :name, required: true, autofocus: true %>
    </div>
    <%= f.submit "ログイン" %>
  <% end %>
  <div>
    <%= link_to '登録ページへ', new_user_path %>
  </div>
</div>

<div>
  <%= link_to "トップページへ", root_path, class: "button" %>
</div>
