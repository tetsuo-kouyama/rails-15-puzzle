<div class="game-container"
     id="game-master"
     data-i18n="<%= puzzle_i18n %>"
     data-difficulty="<%= @difficulty %>"
     data-grid-size="<%= @grid_size %>">

  <header class="game-header">
    <h1><%= t('puzzles.title_with_size', size: @difficulty) %></h1>
  </header>

  <main class="game-body">
    <div class="puzzle-frame"
         style="--frame-url: url('<%= asset_path("frame_stone.png") %>');">
      <div id="puzzle-board"
           style="background-image: url('<%= asset_path("background_wall.png") %>');"
           data-tile-image-url="<%= asset_path('tile_green.png') %>">
      </div>
      <div id="success-toast" class="clear-toast">

        <button id="close-toast" class="close-toast-btn">×</button>
       
        <span id="toast-message" class="text-pixel"></span>
      </div>
    </div>
  </main>

  <footer class="game-footer">
    <div id="controls" class="controls-row">
      <div class="timer-display">
        <div class="timer-bg"
             style="background-image: url('<%= asset_path("timer_base.png") %>');">
          <%= t('puzzles.elapsed_time_html', time_id: content_tag(:span, "00:00", id: "time")) %>
        </div>
      </div>

      <button id="start-button" class="start-btn"
              style="background-image: url('<%= asset_path("start_btn.png")%>');">
        <%= t("puzzles.show.start_button") %>
      </button>
    </div>
  </footer>
</div>



