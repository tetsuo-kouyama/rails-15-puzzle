<h1>ユーザー登録</h1>

<% if @user.errors.any? %>
  <div style="color: red;">
    <h2><%= @user.errors.count %>エラーがあります</h2>
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user do |f| %>
  <div>
    <%= f.label :name, "ユーザー名" %>
    <%= f.text_field :name, required: true, autofocus: true %>
  </div>
  <%= f.submit "登録" %>
<% end %>

<div>
  <%= link_to 'ログインページへ', login_path %>
</div>

<div>
  <%= link_to "トップページへ", root_path %>
</div>
